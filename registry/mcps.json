  {
    "id": "filesystem",
    "name": "Filesystem MCP",
    "author": "Anthropic",
    "version": "1.0.0",
    "description": "Read and write files in allowed directories on your local machine.",
    "long_description": "Gives Claude secure, sandboxed access to your filesystem. You can specify which directories are accessible. Supports read, write, move, copy, and delete operations.",
    "transport": "npm",
    "install_type": "npx",
    "package": "@modelcontextprotocol/server-filesystem",
    "install_cmd": "npx @modelcontextprotocol/server-filesystem {allowed_dir}",
    "config_schema": {
      "allowed_dir": {
        "type": "string",
        "label": "Allowed Directory",
        "placeholder": "/home/user/documents",
        "required": true,
        "description": "Absolute path to directory Claude is allowed to access"
      }
    },
    "claude_config": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "{allowed_dir}"
      ]
    },
    "tags": [
      "files",
      "dev",
      "official"
    ],
    "category": "dev_tools",
    "stars": 4.8,
    "official": true,
    "free": true,
    "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem",
    "icon": "ti-folder",
    "claude_web_compatible": false,
    "platforms": [
      "desktop"
    ]
