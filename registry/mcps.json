    "transport": "docker",
    "install_type": "docker",
    "package": "mcp-grafana",
    "install_cmd": "docker run -p 3001:3001 -e GRAFANA_URL={GRAFANA_URL} -e GRAFANA_API_KEY={GRAFANA_API_KEY} mcp-grafana",
    "config_schema": {
      "GRAFANA_URL": {
        "type": "string",
        "label": "Grafana URL",
        "placeholder": "http://localhost:3000",
        "required": true,
        "description": "Base URL of your Grafana instance"
      },
      "GRAFANA_API_KEY": {
        "type": "secret",
        "label": "Grafana API Key",
        "placeholder": "eyJrIjoixxxxxxxxxx",
        "required": true,
        "description": "Generate in Grafana under Settings > API Keys"
      }
    },
    "claude_config": {
      "command": "docker",
      "args": [
        "run",
        "-p",
        "3001:3001",
        "-e",
        "GRAFANA_URL={GRAFANA_URL}",
        "-e",
        "GRAFANA_API_KEY={GRAFANA_API_KEY}",
        "mcp-grafana"
      ]
    },
