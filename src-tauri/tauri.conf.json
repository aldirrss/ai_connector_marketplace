{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Connector Marketplace",
  "version": "1.0.0",
  "identifier": "com.aldirrss.ai-connector-marketplace",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "AI Connector Marketplace",
        "width": 1200,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../backend", "../registry"],
    "category": "DeveloperTool",
    "shortDescription": "Local app store for MCP servers",
    "longDescription": "Browse, install, and configure MCP servers for Claude Desktop from a single desktop app — no manual JSON editing."
  }
}
